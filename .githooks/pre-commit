#!/bin/bash
#
# Pre-commit hook: blocks secrets, private keys, and identity leaks.
# Scans staged files only (fast).

set -euo pipefail

BLOCKED=false

check_pattern() {
  local pattern="$1"
  local description="$2"
  if git diff --cached --diff-filter=ACMR -z -- | xargs -0 grep -lP "$pattern" 2>/dev/null | head -1 | grep -q .; then
    echo "BLOCKED: $description (pattern: $pattern)"
    BLOCKED=true
  fi
}

# Secrets
check_pattern 'sk-ant-[a-zA-Z0-9_-]{20,}' "Anthropic API key"
check_pattern 'ghp_[a-zA-Z0-9]{36,}' "GitHub personal access token"
check_pattern 'gho_[a-zA-Z0-9]{36,}' "GitHub OAuth token"
check_pattern '-----BEGIN .* PRIVATE KEY-----' "Private key"

# Identity leaks (customize these for your own identity if needed)
# check_pattern 'your-private-username' "Private username leak"

if [ "$BLOCKED" = true ]; then
  echo ""
  echo "Commit blocked. Remove sensitive data before committing."
  exit 1
fi

exit 0
